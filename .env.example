# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# --- Kalshi API credentials (required only for live market-data reads / live mode) ---
# API key id from the Kalshi web app (Account -> API Keys).
KALSHI_API_KEY_ID=

# Absolute path to your RSA PKCS#8 private key file (downloaded when you created the API key).
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi_private_key.pem

# --- Runtime overrides (optional; usually set in config.yaml instead) ---
# COMBO_ARB_MODE=paper            # paper | live
# COMBO_ARB_ENVIRONMENT=prod      # demo | prod

# --- Live-trading triple guard ---
# Placing REAL orders requires ALL of: config.execution.live_enabled=true,
# mode=live, AND this env var set exactly to YES. Leave unset for safety.
# CONFIRM_LIVE_TRADING=
